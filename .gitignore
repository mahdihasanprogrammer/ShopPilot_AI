# Root level ignores
node_modules/
.next/
dist/
build/
out/

# Environments — never commit real secrets
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production
.env.production.local
# Subdirectory env files
client/.env
client/.env.local
client/.env.production
server/.env
server/.env.production
# Keep .example files — those are safe to commit
!**/.env.example
!**/.env.local.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System Files
.DS_Store
Thumbs.db
