# ============================================================
# ShopPilot AI — CLIENT Environment Variables (example)
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# NEXT_PUBLIC_ prefix = exposed to browser (safe public keys only)
# No prefix = Next.js server-side only (never exposed to browser)
# ============================================================

# Backend Express API host (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Better Auth — must match BETTER_AUTH_URL in server/.env
NEXT_PUBLIC_AUTH_URL=http://localhost:5000
# Same secret as server — used only in Next.js server components
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-chars

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret   # server-side only

# Stripe publishable key — safe to expose publicly
# https://dashboard.stripe.com/test/apikeys → Publishable key (pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ImgBB image upload API key
# https://api.imgbb.com/ → Generate API Key
NEXT_PUBLIC_IMGBB_API_KEY=your-imgbb-api-key
