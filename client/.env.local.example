# ============================================================
# ShopPilot AI — CLIENT Environment Variables (example)
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit the actual .env.local file to version control.
# All public variables MUST be prefixed with NEXT_PUBLIC_
# ============================================================

# ── Backend API URL ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── Better Auth (must match server BETTER_AUTH_URL) ─────────
NEXT_PUBLIC_AUTH_URL=http://localhost:5000

# ── ImgBB Image Upload ───────────────────────────────────────
# https://api.imgbb.com/ → Generate API Key
NEXT_PUBLIC_IMGBB_API_KEY=your-imgbb-api-key

# ── Google OAuth (same Client ID as server) ──────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Stripe Publishable Key (safe to expose publicly) ────────
# https://dashboard.stripe.com/test/apikeys → Publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
