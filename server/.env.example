# ============================================================
# ShopPilot AI — SERVER Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=your-mongodb-atlas-connection-string
DATABASE_NAME=shoppilot_db

# ── Better Auth ──────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-better-auth-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:5000

# ── Google OAuth ─────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Anthropic Claude ─────────────────────────────────────────
# Best model: claude-3-5-sonnet-20241022
# https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Stripe Payment Gateway ───────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Client URL (for CORS) ────────────────────────────────────
CLIENT_URL=http://localhost:3000
